# ──────────────────────────────────────────────
# Avatar Pipeline — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your actual keys:
#   cp .env.example .env
# ──────────────────────────────────────────────

# Google Gemini API Key (DEFAULT for phrase generation)
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Anthropic API Key (optional — only needed if using --llm haiku)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Azure Speech Service Key
# Get from: Azure Portal → your Speech resource → Keys and Endpoint
AZURE_SPEECH_KEY=your-azure-speech-key-here

# Azure Speech Service Region
# Must be one of: eastus2, westus2, southeastasia, westeurope, northeurope
# (These are the regions that support Avatar synthesis)
AZURE_SPEECH_REGION=eastus2
